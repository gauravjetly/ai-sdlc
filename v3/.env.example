# ─────────────────────────────────────────────────────────────────────────────
# AI-SDLC v3.0.0 — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Providers (at least one required) ─────────────────────────────────────
AISDLC_DEFAULT_PROVIDER=openai          # openai | anthropic | google | ollama | groq
AISDLC_DEFAULT_MODEL=gpt-4o             # Model name for the chosen provider

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
GROQ_API_KEY=...
OLLAMA_BASE_URL=http://localhost:11434  # For local Ollama

# Any OpenAI-compatible endpoint (LM Studio, vLLM, Together, etc.)
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=

# ── Infrastructure ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
CHROMA_HOST=chromadb
CHROMA_PORT=8001
POSTGRES_URL=postgresql://aisdlc:aisdlc_password@postgres:5432/aisdlc

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── API Server ────────────────────────────────────────────────────────────────
AISDLC_API_HOST=0.0.0.0
AISDLC_API_PORT=8000
AISDLC_API_WORKERS=4
AISDLC_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── MCP Server ────────────────────────────────────────────────────────────────
AISDLC_MCP_PORT=8765
AISDLC_MCP_TRANSPORT=sse               # stdio | sse

# ── Projects ──────────────────────────────────────────────────────────────────
AISDLC_WORKSPACE=/workspace            # Where generated projects are stored
AISDLC_MAX_CONCURRENT_PROJECTS=5

# ── Tool Integrations (all optional) ─────────────────────────────────────────
GITHUB_TOKEN=ghp_...
JIRA_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=...
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0XXXXXXXXX

# ── Cloud Providers (for IaC generation) ─────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AZURE_SUBSCRIPTION_ID=
GCP_PROJECT_ID=

# ── Observability ─────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000
GRAFANA_API_KEY=

# ── Analytics (for weekly reports) ───────────────────────────────────────────
PLAUSIBLE_API_KEY=
PLAUSIBLE_SITE_ID=ai-sdlc.yourdomain.com
PLAUSIBLE_BASE_URL=https://plausible.io
GA4_PROPERTY_ID=
GA4_CREDENTIALS_JSON=

# ── Email (for weekly reports) ────────────────────────────────────────────────
SENDGRID_API_KEY=
REPORT_TO_EMAIL=you@yourdomain.com
REPORT_FROM_EMAIL=analytics@yourdomain.com

# ── Multi-tenancy ─────────────────────────────────────────────────────────────
AISDLC_MULTI_TENANT=false              # Set to true for multi-tenant mode
AISDLC_DEFAULT_TENANT=default

# ── Self-learning ─────────────────────────────────────────────────────────────
AISDLC_SELF_LEARNING=true              # Enable self-learning after each project
AISDLC_LEARNING_MIN_CONFIDENCE=0.75   # Minimum confidence to promote a pattern

# ── Logging ───────────────────────────────────────────────────────────────────
AISDLC_LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
AISDLC_LOG_FORMAT=json                 # json | text
