{
  "name": "@aisdlc/agent-mesh",
  "version": "2.0.0",
  "description": "Inter-agent communication, collective memory, and autonomous learning system for AI-SDLC with semantic vector search and event-driven messaging",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:unit": "jest --testPathPattern='tests/.*\\.test\\.ts$' --testPathIgnorePatterns='integration'",
    "test:integration": "jest --testPathPattern='tests/.*\\.integration\\.test\\.ts$'",
    "lint": "eslint . --ext .ts",
    "mesh:init": "ts-node scripts/init-mesh.ts",
    "mesh:health": "ts-node scripts/health-check.ts",
    "db:migrate": "ts-node scripts/migrate.ts",
    "db:migrate-data": "ts-node scripts/migrate-data.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "uuid": "^9.0.0",
    "pg": "^8.12.0",
    "pg-pool": "^3.6.0",
    "bullmq": "^5.1.0",
    "ioredis": "^5.3.0"
  },
  "optionalDependencies": {
    "pgvector": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@types/pg": "^8.10.0",
    "typescript": "^5.3.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0"
  },
  "keywords": [
    "ai-sdlc",
    "agent-mesh",
    "inter-agent-communication",
    "collective-memory",
    "learning-engine",
    "semantic-search",
    "pgvector",
    "bullmq",
    "event-driven"
  ]
}
