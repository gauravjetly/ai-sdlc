{
  "name": "@vintiq/governance-engine",
  "version": "1.0.0",
  "description": "Vintiq Engineering Governance Policy Engine - Enforce coding standards automatically",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "governance": "dist/presentation/cli/index.js"
  },
  "files": [
    "dist",
    "config"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "validate": "ts-node src/presentation/cli/index.ts validate",
    "check": "ts-node src/presentation/cli/index.ts check",
    "prepublishOnly": "npm run build && npm run test"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "uuid": "^9.0.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "@types/uuid": "^9.0.6",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "eslint": "^8.53.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  },
  "peerDependencies": {
    "typescript": ">=4.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "governance",
    "policy",
    "security",
    "linting",
    "architecture",
    "validation",
    "pre-commit",
    "ci-cd",
    "code-quality"
  ],
  "author": "Vintiq Engineering",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DLTKEngineering/governance-engine.git"
  },
  "bugs": {
    "url": "https://github.com/DLTKEngineering/governance-engine/issues"
  },
  "homepage": "https://github.com/DLTKEngineering/governance-engine#readme"
}
