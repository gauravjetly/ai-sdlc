{
  "name": "@aisdlc/integration",
  "version": "1.0.0",
  "description": "AI-SDLC Integration Foundation: Request classifier, smart router, governance engine, and configuration system for Claude Code integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --watch --config jest.config.js",
    "test:coverage": "jest --coverage --config jest.config.js",
    "lint": "tsc --noEmit",
    "demo": "ts-node cli/interactive-demo.ts",
    "test:classify": "ts-node cli/test-classifier.ts --batch",
    "test:route": "ts-node cli/test-router.ts",
    "test:governance": "ts-node cli/test-governance.ts",
    "test:config": "ts-node cli/test-config.ts"
  },
  "dependencies": {
    "uuid": "^9.0.0",
    "yaml": "^2.3.0",
    "zod": "^3.22.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.50.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.3.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0"
  },
  "keywords": [
    "aisdlc",
    "claude-code",
    "integration",
    "classifier",
    "router",
    "governance",
    "sdlc"
  ]
}
