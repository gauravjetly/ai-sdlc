{
  "name": "@platform/multicloud-devops",
  "version": "1.0.0",
  "description": "Multi-Cloud DevOps Platform - Cloud Abstraction Layer",
  "main": "index.js",
  "type": "module",
  "bin": {
    "platform": "./cli/platform-cli.js"
  },
  "prisma": {
    "seed": "tsx prisma/seeds/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch cli/platform-cli.ts",
    "api:start": "tsx api/server.ts",
    "api:dev": "tsx watch api/server.ts",
    "api:test": "jest --testPathPattern=tests/api --runInBand",
    "setup:jwt": "./scripts/generate-jwt-keys.sh",
    "mcp:start": "node dist/mcp/server/mcp-server.js",
    "mcp:dev": "tsx watch mcp/server/mcp-server.ts",
    "mcp:http": "node dist/mcp/server/http-server.js",
    "mcp:http:dev": "tsx watch mcp/server/http-server.ts",
    "mcp:test": "jest --testPathPattern=tests/mcp",
    "mcp:tools": "tsx scripts/list-mcp-tools.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:seed:templates": "tsx prisma/seeds/index.ts",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "test": "jest",
    "test:all": "jest --coverage --runInBand",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration --runInBand --detectOpenHandles --forceExit",
    "test:e2e": "jest --testPathPattern=tests/e2e --runInBand --detectOpenHandles --forceExit --testTimeout=60000",
    "test:api": "jest --testPathPattern=tests/api --runInBand",
    "test:load": "jest --testPathPattern=tests/load --runInBand --testTimeout=600000",
    "test:mcp": "jest --testPathPattern=tests/mcp",
    "test:templates": "jest --testPathPattern=prisma/seeds/__tests__",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageDirectory=coverage",
    "test:coverage:report": "jest --coverage && open coverage/lcov-report/index.html",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:verbose": "jest --verbose",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "cloud",
    "devops",
    "kubernetes",
    "aws",
    "oci",
    "multi-cloud"
  ],
  "author": "Platform Team",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-cloudtrail": "^3.978.0",
    "@aws-sdk/client-cloudwatch": "^3.978.0",
    "@aws-sdk/client-cost-explorer": "^3.978.0",
    "@aws-sdk/client-ec2": "^3.978.0",
    "@aws-sdk/client-eks": "^3.978.0",
    "@aws-sdk/client-iam": "^3.978.0",
    "@aws-sdk/client-rds": "^3.978.0",
    "@aws-sdk/client-s3": "^3.978.0",
    "@aws-sdk/client-sts": "^3.978.0",
    "@aws-sdk/credential-providers": "^3.978.0",
    "@kubernetes/client-node": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@prisma/client": "5.22.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "bullmq": "^5.67.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
    "joi": "^18.0.2",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "oci-common": "^2.84.0",
    "oci-containerengine": "^2.84.0",
    "oci-core": "^2.84.0",
    "oci-database": "^2.84.0",
    "oci-identity": "^2.84.0",
    "oci-objectstorage": "^2.84.0",
    "oci-sdk": "^2.84.0",
    "pg": "^8.17.2",
    "prisma": "5.22.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
