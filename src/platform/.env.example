# Deltek Catalyst Platform Configuration
# Real Services Configuration - NO MOCK DATA

# ==================================
# DATABASE (PostgreSQL)
# ==================================
DATABASE_URL="postgresql://catalyst:catalyst_password@localhost:5432/catalyst_platform?schema=public"
DATABASE_SSL=false

# ==================================
# REDIS (Job Queue & Cache)
# ==================================
REDIS_URL="redis://localhost:6379"

# ==================================
# API SERVER
# ==================================
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001

# ==================================
# JWT AUTHENTICATION
# ==================================
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=24h

# ==================================
# AWS CREDENTIALS
# ==================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# ==================================
# OCI CREDENTIALS
# ==================================
OCI_TENANCY_ID=your-oci-tenancy-id
OCI_USER_ID=your-oci-user-id
OCI_FINGERPRINT=your-oci-fingerprint
OCI_REGION=us-phoenix-1
OCI_PRIVATE_KEY_PATH=/path/to/oci/private_key.pem

# ==================================
# KUBERNETES
# ==================================
KUBECONFIG=/path/to/kubeconfig
# Or leave empty to use default (~/.kube/config)

# ==================================
# SECURITY SCANNING
# ==================================
# National Vulnerability Database API
NVD_API_KEY=your-nvd-api-key

# ==================================
# WEBSOCKET
# ==================================
WS_PORT=3001

# ==================================
# LOGGING
# ==================================
LOG_LEVEL=info
LOG_FORMAT=json

# ==================================
# COST OPTIMIZATION
# ==================================
# Enable AWS Cost Explorer
ENABLE_COST_EXPLORER=true
