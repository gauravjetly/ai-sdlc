{
  "dashboard": {
    "title": "AI-SDLC Platform - Cost Analysis",
    "description": "Real-time cost monitoring and optimization tracking",
    "tags": ["cost", "finops", "optimization", "ai-sdlc"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "5m",
    "time": {
      "from": "now-30d",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Daily Cost",
        "type": "stat",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "cost_daily_usd",
            "refId": "A",
            "legendFormat": "Today's Cost"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "decimals": 2
          }
        }
      },
      {
        "id": 2,
        "title": "Monthly Projection",
        "type": "stat",
        "gridPos": {
          "x": 6,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "cost_monthly_projection_usd",
            "refId": "A",
            "legendFormat": "Monthly Projection"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "decimals": 2
          }
        }
      },
      {
        "id": 3,
        "title": "Forecast Accuracy",
        "type": "gauge",
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "cost_forecast_accuracy_percent",
            "refId": "A",
            "legendFormat": "Accuracy"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "red" },
                { "value": 80, "color": "yellow" },
                { "value": 95, "color": "green" }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Optimization Savings",
        "type": "stat",
        "gridPos": {
          "x": 18,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "optimization_savings_usd",
            "refId": "A",
            "legendFormat": "Total Savings"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "decimals": 2,
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "red" },
                { "value": 100, "color": "yellow" },
                { "value": 500, "color": "green" }
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Cost Trend (30 days)",
        "type": "graph",
        "gridPos": {
          "x": 0,
          "y": 4,
          "w": 24,
          "h": 8
        },
        "targets": [
          {
            "expr": "cost_daily_usd",
            "refId": "A",
            "legendFormat": "Daily Cost"
          },
          {
            "expr": "avg_over_time(cost_daily_usd[7d])",
            "refId": "B",
            "legendFormat": "7-day Average"
          }
        ],
        "yaxes": [
          {
            "format": "currencyUSD",
            "label": "Cost (USD)"
          },
          {
            "format": "short"
          }
        ],
        "lines": true,
        "fill": 1
      },
      {
        "id": 6,
        "title": "Cost by Cloud Provider",
        "type": "piechart",
        "gridPos": {
          "x": 0,
          "y": 12,
          "w": 8,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum by (cloud_provider) (cost_by_cloud_usd)",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right",
            "values": ["value", "percent"]
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD"
          }
        }
      },
      {
        "id": 7,
        "title": "Cost by Environment",
        "type": "piechart",
        "gridPos": {
          "x": 8,
          "y": 12,
          "w": 8,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum by (environment) (cost_by_environment_usd)",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right",
            "values": ["value", "percent"]
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD"
          }
        }
      },
      {
        "id": 8,
        "title": "Cost by Service",
        "type": "piechart",
        "gridPos": {
          "x": 16,
          "y": 12,
          "w": 8,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum by (service) (cost_by_service_usd)",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right",
            "values": ["value", "percent"]
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD"
          }
        }
      },
      {
        "id": 9,
        "title": "Top 10 Cost Contributors",
        "type": "table",
        "gridPos": {
          "x": 0,
          "y": 20,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "topk(10, cost_by_resource_usd)",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "renameByName": {
                "resource": "Resource",
                "Value": "Cost (USD)"
              }
            }
          }
        ]
      },
      {
        "id": 10,
        "title": "Optimization Opportunities",
        "type": "table",
        "gridPos": {
          "x": 12,
          "y": 20,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "waste_detected_usd",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "renameByName": {
                "resource": "Resource",
                "waste_type": "Waste Type",
                "Value": "Potential Savings (USD)"
              }
            }
          }
        ]
      },
      {
        "id": 11,
        "title": "Cost vs Budget",
        "type": "bargauge",
        "gridPos": {
          "x": 0,
          "y": 28,
          "w": 24,
          "h": 6
        },
        "targets": [
          {
            "expr": "cost_monthly_projection_usd",
            "refId": "A",
            "legendFormat": "Projected Cost"
          },
          {
            "expr": "cost_monthly_budget_usd",
            "refId": "B",
            "legendFormat": "Budget"
          }
        ],
        "options": {
          "displayMode": "gradient",
          "orientation": "horizontal"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "thresholds": {
              "mode": "percentage",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 80, "color": "yellow" },
                { "value": 100, "color": "red" }
              ]
            }
          }
        }
      }
    ]
  }
}
