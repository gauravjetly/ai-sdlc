{
  "dashboard": {
    "title": "AI-SDLC Platform - Deployments",
    "description": "Real-time deployment metrics and monitoring",
    "tags": ["deployments", "ai-sdlc", "platform"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Deployment Success Rate",
        "type": "stat",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "(deployments_success_total / deployments_total) * 100",
            "refId": "A",
            "legendFormat": "Success Rate"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          },
          "orientation": "horizontal",
          "textMode": "value_and_name",
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "red" },
                { "value": 90, "color": "yellow" },
                { "value": 95, "color": "green" }
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Active Deployments",
        "type": "stat",
        "gridPos": {
          "x": 6,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "deployments_active",
            "refId": "A",
            "legendFormat": "Active"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          },
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 3,
        "title": "In Progress Deployments",
        "type": "stat",
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "deployments_in_progress",
            "refId": "A",
            "legendFormat": "In Progress"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          },
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 4,
        "title": "Total Deployments",
        "type": "stat",
        "gridPos": {
          "x": 18,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "deployments_total",
            "refId": "A",
            "legendFormat": "Total"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          },
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 5,
        "title": "Deployment Rate (per hour)",
        "type": "graph",
        "gridPos": {
          "x": 0,
          "y": 4,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "rate(deployments_total[1h])",
            "refId": "A",
            "legendFormat": "Deployment Rate"
          }
        ],
        "yaxes": [
          {
            "format": "short",
            "label": "Deployments/hour"
          },
          {
            "format": "short"
          }
        ]
      },
      {
        "id": 6,
        "title": "Deployment Status Distribution",
        "type": "piechart",
        "gridPos": {
          "x": 12,
          "y": 4,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "deployments_success_total",
            "refId": "A",
            "legendFormat": "Success"
          },
          {
            "expr": "deployments_failed_total",
            "refId": "B",
            "legendFormat": "Failed"
          },
          {
            "expr": "deployments_rolled_back_total",
            "refId": "C",
            "legendFormat": "Rolled Back"
          }
        ]
      },
      {
        "id": 7,
        "title": "Deployment Duration (P50, P95, P99)",
        "type": "graph",
        "gridPos": {
          "x": 0,
          "y": 12,
          "w": 24,
          "h": 8
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, deployment_duration_seconds)",
            "refId": "A",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.95, deployment_duration_seconds)",
            "refId": "B",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, deployment_duration_seconds)",
            "refId": "C",
            "legendFormat": "P99"
          }
        ],
        "yaxes": [
          {
            "format": "s",
            "label": "Duration"
          },
          {
            "format": "short"
          }
        ]
      },
      {
        "id": 8,
        "title": "Deployments by Environment",
        "type": "table",
        "gridPos": {
          "x": 0,
          "y": 20,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum by (environment) (deployments_total)",
            "refId": "A",
            "format": "table"
          }
        ]
      },
      {
        "id": 9,
        "title": "Deployments by Strategy",
        "type": "table",
        "gridPos": {
          "x": 12,
          "y": 20,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum by (strategy) (deployments_total)",
            "refId": "A",
            "format": "table"
          }
        ]
      }
    ]
  }
}
